generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String
  avatarUrl        String?
  emailVerified    Boolean   @default(false)
  verificationOtp  String?
  verificationExp  DateTime?
  resetOtp         String?
  resetOtpExp      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  groupMemberships GroupMember[]
  expensesPaid     Expense[]        @relation("PaidBy")
  expenseSplits    ExpenseSplit[]
  settlementsPaid  Settlement[]     @relation("SettlementPayer")
  settlementsReceived Settlement[]  @relation("SettlementReceiver")
  invitationsSent  Invitation[]     @relation("InvitedBy")
  personalExpenses PersonalExpense[]
  incomeEntries    IncomeEntry[]
  investments      Investment[]
  liabilities      Liability[]
  savingsGoals     SavingsGoal[]
  budgets          Budget[]
  comments         Comment[]
  notifications    Notification[]
  recurringExpenses RecurringExpense[]
  activityLogs       ActivityLog[]
  chatMessages     ChatMessage[]
  reminders        Reminder[]
  starredExpenses  StarredExpense[]
  expenseTemplates ExpenseTemplate[]

  @@index([email])
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  currency    String    @default("INR")
  groupType   GroupType @default(FRIENDS)
  archived    Boolean   @default(false)
  inviteLink  String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  invitations  Invitation[]
  activityLogs ActivityLog[]
  chatMessages ChatMessage[]

  @@index([name])
  @@index([inviteLink])
}

enum GroupType {
  TRIP
  ROOMMATES
  FRIENDS
  COUPLE
  CUSTOM
}

model GroupMember {
  id        String      @id @default(cuid())
  role      MemberRole  @default(MEMBER)
  joinedAt  DateTime    @default(now())

  userId    String
  groupId   String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Expense {
  id             String         @id @default(cuid())
  title          String
  amount         Float
  category       String         @default("other")
  date           DateTime       @default(now())
  note           String?
  receiptUrl     String?
  splitType      SplitType      @default(EQUAL)
  tags           String[]       @default([])
  currency       String?
  approvalStatus ApprovalStatus @default(APPROVED)
  isDeleted      Boolean        @default(false)
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  paidById    String
  groupId     String
  paidBy      User        @relation("PaidBy", fields: [paidById], references: [id])
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  splits      ExpenseSplit[]
  comments    Comment[]
  starred     StarredExpense[]

  @@index([groupId])
  @@index([paidById])
  @@index([date])
  @@index([isDeleted])
  @@index([approvalStatus])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

model ExpenseSplit {
  id          String   @id @default(cuid())
  amount      Float
  percentage  Float?
  shares      Int?

  expenseId   String
  userId      String
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
  @@index([expenseId])
}

model Settlement {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  payerId   String
  receiverId String
  groupId   String
  payer     User     @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver  User     @relation("SettlementReceiver", fields: [receiverId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([payerId])
  @@index([receiverId])
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  inviteToken String           @unique @default(cuid())
  status      InvitationStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  groupId     String
  invitedById String
  group       Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy   User   @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email])
  @@index([inviteToken])
  @@index([groupId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model PersonalExpense {
  id        String   @id @default(cuid())
  amount    Float
  category  String   @default("other")
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model IncomeEntry {
  id         String     @id @default(cuid())
  source     String
  type       IncomeType @default(OTHER)
  amount     Float
  receivedAt DateTime   @default(now())
  recurring  Boolean    @default(false)
  note       String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([receivedAt])
  @@index([type])
}

enum IncomeType {
  SALARY
  FREELANCE
  BUSINESS
  RENTAL
  INTEREST
  DIVIDEND
  BONUS
  REFUND
  GIFT
  OTHER
}

model Investment {
  id             String         @id @default(cuid())
  name           String
  type           InvestmentType @default(OTHER)
  investedAmount Float
  currentValue   Float
  investedAt     DateTime       @default(now())
  platform       String?
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([investedAt])
  @@index([type])
}

enum InvestmentType {
  STOCK
  MUTUAL_FUND
  ETF
  FIXED_DEPOSIT
  CRYPTO
  GOLD
  REAL_ESTATE
  PPF
  NPS
  BOND
  OTHER
}

model Liability {
  id                String        @id @default(cuid())
  name              String
  type              LiabilityType @default(LOAN)
  totalAmount       Float
  outstandingAmount Float
  interestRate      Float?
  minimumDue        Float?
  dueDate           DateTime?
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueDate])
  @@index([type])
}

enum LiabilityType {
  LOAN
  CREDIT_CARD
  MORTGAGE
  PERSONAL_BORROW
  EMI
  OTHER
}

model SavingsGoal {
  id           String     @id @default(cuid())
  title        String
  targetAmount Float
  currentAmount Float     @default(0)
  targetDate   DateTime?
  status       GoalStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  PAUSED
}

model Budget {
  id             String   @id @default(cuid())
  monthlyLimit   Float
  categoryBudgets Json?   @default("{}")
  month          Int
  year           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  expenseId String
  userId    String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([expenseId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  GROUP_INVITE
  NEW_EXPENSE
  SETTLEMENT
  BUDGET_WARNING
  GENERAL
  MEMBER_JOINED
  MEMBER_LEFT
  ROLE_CHANGED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  REMINDER
  CHAT_MESSAGE
}

model RecurringExpense {
  id          String    @id @default(cuid())
  title       String
  amount      Float
  category    String    @default("bills")
  frequency   Frequency
  nextDue     DateTime
  groupId     String?
  splitType   SplitType @default(EQUAL)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextDue])
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  groupId   String
  userId    String
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id])

  @@index([groupId])
  @@index([createdAt])
}

// Feature 9: Group Chat
model ChatMessage {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  groupId   String
  userId    String
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id])

  @@index([groupId])
  @@index([createdAt])
}

// Feature 8: Reminders
model Reminder {
  id         String        @id @default(cuid())
  message    String
  amount     Float?
  status     ReminderStatus @default(PENDING)
  sendAt     DateTime      @default(now())
  sentAt     DateTime?
  createdAt  DateTime      @default(now())

  fromUserId String
  toUserId   String
  groupId    String?
  fromUser   User   @relation(fields: [fromUserId], references: [id])

  @@index([toUserId])
  @@index([fromUserId])
  @@index([status])
}

enum ReminderStatus {
  PENDING
  SENT
  DISMISSED
}

// Feature 14: Starred/Pinned Expenses
model StarredExpense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  expenseId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([userId, expenseId])
  @@index([userId])
}

// Feature 13: Expense Templates
model ExpenseTemplate {
  id          String    @id @default(cuid())
  name        String
  title       String
  amount      Float?
  category    String    @default("other")
  splitType   SplitType @default(EQUAL)
  splits      Json?     // Store split config as JSON
  groupId     String?
  createdAt   DateTime  @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
